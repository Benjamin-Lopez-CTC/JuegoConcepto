@model JuegoConcepto.Models.GameState
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Juego de Colores";
}

<div class="game-wrapper">

    <!-- ═══ ENCABEZADO ════════════════════════════════ -->
    <div class="game-header">
        <h1>🎨 Juego de Colores</h1>
        <p>Ningún color puede repetirse. ¡Todos deben pasar antes de que alguien vuelva!</p>
    </div>

    <!-- ═══ FASE: CONFIGURACIÓN ══════════════════════ -->
    @if (Model.Phase == JuegoConcepto.Models.GamePhase.Setup)
    {
        <div class="card">
            <div class="card-title">Jugadores</div>

            <!-- Agregar jugador -->
            <form asp-action="AddPlayer" method="post" id="formAddPlayer">
                <div class="player-input-row">
                    <input type="text"
                           name="playerName"
                           id="inputPlayerName"
                           placeholder="Nombre del jugador..."
                           autocomplete="off"
                           maxlength="40"
                           required />
                    <button type="submit" class="btn btn-primary">Agregar</button>
                </div>
            </form>

            <!-- Contador y lista -->
            @if (Model.Players.Count > 0)
            {
                <div class="player-count">@Model.Players.Count jugador(es) añadido(s)</div>
            }

            <ul class="player-list" id="playerList">
                @if (Model.Players.Count == 0)
                {
                    <li class="no-players" style="list-style:none;border:none;background:none;">
                        Aún no hay jugadores. Agrega al menos 2 para comenzar.
                    </li>
                }
                else
                {
                    for (int i = 0; i < Model.Players.Count; i++)
                    {
                        int idx = i;
                        <li>
                            <span class="index">@(i + 1)</span>
                            <span class="name">@Model.Players[i]</span>
                            <form asp-action="RemovePlayer" method="post" style="margin:0">
                                <input type="hidden" name="index" value="@idx" />
                                <button type="submit" class="btn-remove" title="Eliminar">✕</button>
                            </form>
                        </li>
                    }
                }
            </ul>

            <div class="divider"></div>

            <!-- Botones iniciar y finalizar -->
            <div style="display:flex; gap:0.5rem; flex-direction:column;">
                <form asp-action="StartGame" method="post">
                    <button type="submit"
                            class="btn btn-success btn-block"
                            @(Model.Players.Count < 2 ? "disabled" : "")>
                        ▶ Iniciar Partida (@Model.Players.Count jugadores)
                    </button>
                </form>
                @if (Model.Players.Count >= 2)
                {
                    <form asp-action="EndRound" method="post">
                        <button type="submit" class="btn btn-danger btn-block">
                            ⏹ Finalizar Ronda y ver Resultados
                        </button>
                    </form>
                }
            </div>
            
            @if (Model.Players.Count < 2)
            {
                <p style="text-align:center;font-size:0.8rem;color:var(--text-dim);margin-top:0.5rem;">
                    Necesitas al menos 2 jugadores para configurar una ronda.
                </p>
            }
        </div>
    }

    <!-- ═══ FASE: JUGANDO ════════════════════════════ -->
    @if (Model.Phase == JuegoConcepto.Models.GamePhase.Playing)
    {
        <!-- Cronómetro -->
        <div class="timer-display">
            <div class="time" id="timerDisplay">00:00</div>
            <div class="time-label">tiempo transcurrido</div>
        </div>

        <!-- Jugador actual -->
        <div class="card current-player-card">
            <div class="player-label">Turno de</div>
            <div class="player-name">@Model.CurrentPlayerName</div>
            <div class="player-instruction">Di un color que nadie haya dicho</div>

            <form asp-action="SubmitColor" method="post" id="formColor">
                <input type="hidden" name="elapsedMs" id="hiddenElapsed" value="0" />
                <div class="color-input-row">
                    <input type="text"
                           name="color"
                           id="inputColor"
                           placeholder="Escribe el color aquí..."
                           autocomplete="off"
                           maxlength="50"
                           autofocus
                           required />
                    <button type="submit" class="btn btn-primary" id="btnSubmitColor">
                        Continuar →
                    </button>
                </div>
            </form>
        </div>

        <!-- Progreso de ronda -->
        <div class="card" style="padding:1.25rem 1.75rem">
            <div class="card-title">Progreso · Ronda actual</div>
            <div class="progress-track" id="progressTrack">
                @for (int i = 0; i < Model.Players.Count; i++)
                {
                    string cls = i < (Model.ColorHistory.Count % Model.Players.Count) ? "progress-dot done" : "progress-dot";
                    if (Model.ColorHistory.Count % Model.Players.Count == 0 && Model.ColorHistory.Count > 0)
                        cls = "progress-dot done";
                    <div class="@cls"></div>
                }
            </div>
            <div class="round-info">
                <span class="round-badge">
                    Jugadores completados: @Model.ColorHistory.Count
                </span>
                <span>·</span>
                <span>@Model.Players.Count en total</span>
            </div>
        </div>

        <!-- Historial de colores usados -->
        @if (Model.ColorHistory.Count > 0)
        {
            <div class="card">
                <div class="card-title">Colores ya dichos</div>
                <div class="history-grid">
                    @foreach (var entry in Model.ColorHistory)
                    {
                        <div class="history-chip">
                            <div class="chip-dot"></div>
                            <span class="chip-name">@entry.PlayerName</span>
                            <span class="chip-color">→ @entry.Color</span>
                        </div>
                    }
                </div>
            </div>
        }

        <!-- Botón reiniciar -->
        <div style="text-align:right;margin-top:0.5rem">
            <form asp-action="ResetGame" method="post" style="display:inline">
                <button type="submit" class="btn btn-ghost" style="font-size:0.8rem;padding:0.5rem 1rem">
                    ↩ Reiniciar partida
                </button>
            </form>
        </div>
    }

    <!-- ═══ FASE: GANARON (Esperando ID) ═════════════════ -->
    @if (Model.Phase == JuegoConcepto.Models.GamePhase.WonPendingId)
    {
        <div class="card result-card">
            <div class="result-icon">🏆</div>
            <div class="result-title won">¡Partida Completada!</div>
            <div class="result-subtitle">
                @Model.WinningReason
            </div>

            <div class="result-stats">
                <div class="stat-box">
                    <div class="stat-value" id="statTime">--:--</div>
                    <div class="stat-label">Tiempo de partida</div>
                </div>
            </div>

            <div class="divider" style="margin-top:2rem"></div>
            
            <h3 style="font-size:1.1rem; margin-bottom:1rem;">Registrar en Leaderboard</h3>
            <form asp-action="SaveWinningId" method="post" style="display:flex; flex-direction:column; align-items:center; gap:1rem;">
                <input type="text"
                       name="winningIdentifier"
                       placeholder="Nombre de equipo o jugador..."
                       class="player-input-row"
                       style="padding:0.75rem; border-radius:var(--radius-sm); border:1px solid var(--border); background:var(--surface-2); color:white; width:100%; text-align:center;"
                       required autofocus autocomplete="off" />
                <button type="submit" class="btn btn-success btn-block">Guardar Resultados</button>
            </form>
        </div>

        <input type="hidden" id="savedElapsed" value="@Model.ElapsedMilliseconds" />
    }

    <!-- ═══ FASE: PERDIERON ══════════════════════════ -->
    @if (Model.Phase == JuegoConcepto.Models.GamePhase.Lost)
    {
        <div class="card result-card">
            <div class="result-icon">💥</div>
            <div class="result-title lost">¡Perdieron!</div>
            <div class="result-subtitle">
                @Model.WinningReason
            </div>

            <div class="result-stats">
                <div class="stat-box">
                    <div class="stat-value" id="statTime">--:--</div>
                    <div class="stat-label">Tiempo</div>
                </div>
                <div class="stat-box">
                    <div class="stat-value">@Model.PlayersReached</div>
                    <div class="stat-label">Colores antes de fallar</div>
                </div>
            </div>

            @if (Model.ColorHistory.Count > 0)
            {
                <div class="card" style="text-align:left;margin-top:1rem">
                    <div class="card-title">Colores dichos</div>
                    <div class="history-grid">
                        @foreach (var entry in Model.ColorHistory)
                        {
                            <div class="history-chip">
                                <div class="chip-dot"></div>
                                <span class="chip-name">@entry.PlayerName</span>
                                <span class="chip-color">→ @entry.Color</span>
                            </div>
                        }
                    </div>
                </div>
            }

            <div class="result-actions">
                <form asp-action="ResetGame" method="post">
                    <button type="submit" class="btn btn-primary">▶ Continuar a otra partida</button>
                </form>
                <form asp-action="EndRound" method="post">
                    <button type="submit" class="btn btn-danger">⏹ Finalizar Ronda</button>
                </form>
            </div>
        </div>

        <input type="hidden" id="savedElapsed" value="@Model.ElapsedMilliseconds" />
    }

</div>

@section Scripts {
<script>
(function () {
    /* ── Cronómetro ──────────────────────────────────────── */
    const phase = "@Model.Phase";
    const timerEl = document.getElementById('timerDisplay');
    const hiddenElapsed = document.getElementById('hiddenElapsed');
    const statTimeEl = document.getElementById('statTime');
    const savedElapsedEl = document.getElementById('savedElapsed');

    function formatTime(ms) {
        const totalSec = Math.floor(ms / 1000);
        const min = Math.floor(totalSec / 60).toString().padStart(2, '0');
        const sec = (totalSec % 60).toString().padStart(2, '0');
        return `${min}:${sec}`;
    }

    if (phase === 'Playing' && timerEl) {
        // El tiempo inicia desde el servidor; usamos sessionStorage para mantener
        // el offset entre recargas de página (cada submit hace redirect).
        const KEY = 'gameStartTs';
        let stored = sessionStorage.getItem(KEY);
        if (!stored) {
            stored = Date.now().toString();
            sessionStorage.setItem(KEY, stored);
        }
        const startTs = parseInt(stored, 10);

        function tick() {
            const elapsed = Date.now() - startTs;
            timerEl.textContent = formatTime(elapsed);
            if (hiddenElapsed) hiddenElapsed.value = elapsed;
        }
        tick();
        setInterval(tick, 500);

        // Al enviar, guardar tiempo en el hidden input
        const form = document.getElementById('formColor');
        if (form) {
            form.addEventListener('submit', function () {
                if (hiddenElapsed) hiddenElapsed.value = Date.now() - startTs;
            });
        }
    } else {
        // Fin del juego: limpiar la clave y mostrar tiempo guardado
        sessionStorage.removeItem('gameStartTs');

        if (statTimeEl && savedElapsedEl) {
            const ms = parseInt(savedElapsedEl.value || '0', 10);
            statTimeEl.textContent = formatTime(ms);
        }
    }

    /* ── Foco automático en el campo de nombre ────────── */
    const inputName = document.getElementById('inputPlayerName');
    if (inputName) inputName.focus();

    /* ── Foco automático en el campo de color ─────────── */
    const inputColor = document.getElementById('inputColor');
    if (inputColor) inputColor.focus();

    /* ── Limpiar campo de nombre al agregar ────────────── */
    const formAdd = document.getElementById('formAddPlayer');
    if (formAdd) {
        formAdd.addEventListener('submit', function () {
            // El campo se limpiará al recargar la página
        });
    }
})();
</script>
}
