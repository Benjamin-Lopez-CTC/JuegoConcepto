<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Juego de Colores</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/game.css" asp-append-version="true" />
</head>
<body>
    <nav class="top-nav">
        <a asp-controller="Home" asp-action="Index" class="@(ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "")">Juego</a>
        <a asp-controller="Home" asp-action="TechStack" class="@(ViewContext.RouteData.Values["Action"]?.ToString() == "TechStack" ? "active" : "")">Stack Tecnológico</a>
    </nav>
    @RenderBody()
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
